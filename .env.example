# Telegram Bot Token - @BotFather dan oling
BOT_TOKEN=your_bot_token_here

# Storage kanal ID - Kanalning ID raqami (manfiy bo'lishi mumkin)
# Misol: -1001234567890
STORAGE_CHANNEL_ID=-1001234567890

# Admin ID lari - vergul bilan ajrating
# Misol: 123456789,987654321
ADMIN_IDS=123456789

# Ma'lumotlar bazasi fayl yo'li (Railway uchun ixtiyoriy)
DB_PATH=storage_bot.db
